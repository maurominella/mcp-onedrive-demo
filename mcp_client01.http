# either http://localhost:8000 or  http://localhost:8010 or https://mcp-onedrive-demo.ambitiousrock-79574fa4.swedencentral.azurecontainerapps.io
@baseUrl = http://localhost:8000

@foundry_project_endpoint = https://foundry7159.services.ai.azure.com/api/projects/aif7159-standard-agent-project

@agent_name = custom-mcp-agent-01
@agent_version = 5


### get the list of tools - UN-AUTHENTICATED or FAKE-AUTEHTNCIATION, just to see the metadata of the tools
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Authorization: Bearer {{bearertoken_for_mcp}}

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "tools/list",
  "params": {}
}


### runs WhoAmI tool to verify the authentication and get the user info
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Authorization: Bearer {{bearertoken_for_mcp}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {"name":"WhoAmI","arguments":{}}
}


### runs create_ticket tool to verify the authentication and get the user info
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Authorization: Bearer {{bearertoken_for_mcp}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {"name":"create_ticket","arguments":{"description":"My computer is on fire"}}
}


### invoke an MCP tool (e.g. get_onedrive_root_folders)
POST {{baseUrl}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
Authorization: Bearer {{bearertoken_for_mcp}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {"name":"get_onedrive_root_folders","arguments":{}}
}

### invoke MS Graph API directly, using the graph access token (not the MCP token)
GET https://graph.microsoft.com/v1.0/me/drive/root/children
Content-Type: application/json
Authorization: Bearer {{bearertoken_for_msgraph}}

### invoke the agent
POST {{foundry_project_endpoint}}/responses?api-version=2024-10-01-preview
Content-Type: application/json
Authorization: Bearer {{bearertoken_for_aiazurecom}}

{
  "input": [{"role": "user", "content": "what can you do?"}],
  "extra_body": {"agent_reference": {"name": "{{agent_name}}", "version": "{{agent_version}}", "type": "agent_reference"}}
}